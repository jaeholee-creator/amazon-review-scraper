# Amazon US 크롤러 설정
AMAZON_EMAIL=your_email@example.com
AMAZON_PASSWORD=your_password

# Amazon UK 크롤러 설정
AMAZON_EMAIL_UK=your_uk_email@example.com
AMAZON_PASSWORD_UK=your_uk_password

# Google Sheets 설정 (공통)
GOOGLE_SHEETS_SERVICE_ACCOUNT_FILE=config/service-account.json

# Biodance 크롤러 설정  
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# 로컬 파일 저장 여부 (선택, 기본값: true)
SAVE_LOCAL_FILES=true

# Slack 알림 (선택)
SLACK_WEBHOOK_URL=your_slack_webhook_url

# TikTok Shop Seller Center 설정
TIKTOK_EMAIL=your_tiktok_email@example.com
TIKTOK_PASSWORD=your_tiktok_password

# TikTok Gmail IMAP (인증 코드 자동 읽기용, 선택)
TIKTOK_GMAIL_IMAP_EMAIL=
TIKTOK_GMAIL_IMAP_APP_PASSWORD=

# EulerStream API (TikTok 캡차 솔버, 무료 25건/일)
# https://eulerstream.com 에서 API 키 발급
EULER_STREAM_API_KEY=

# BigQuery 설정 (데이터 적재 방식 선택)
PUBLISHER_TYPE=bigquery  # bigquery 또는 sheets
GCP_PROJECT_ID=member-378109
BIGQUERY_DATASET_ID=jaeho
BIGQUERY_TABLE_ID=platform_reviews

# =============================================================================
# Amazon 상품 카탈로그 동기화 설정
# =============================================================================

# 스크래핑 전 Amazon 브랜드 검색 기반 상품 목록 자동 동기화 여부
# true(기본): 실행 시마다 신규/삭제 상품 감지 후 products.csv 업데이트
# false: 기존 products.csv 그대로 사용 (테스트 또는 빠른 실행 시)
SYNC_PRODUCTS=true

# Amazon SP-API 자격증명 (향후 Listings API 연동 시 사용)
# Amazon Developer Console에서 발급: https://developer.amazonservices.com/
# 현재는 브랜드 검색 크롤링 방식을 사용하므로 설정 불필요
SP_API_CLIENT_ID=amzn1.application-oa2-client.your_client_id
SP_API_CLIENT_SECRET=amzn1.oa2-cs.v1.your_client_secret
SP_API_REFRESH_TOKEN=Atzr|your_refresh_token
# SP-API 호출에는 AWS SigV4 서명도 필요합니다:
SP_API_AWS_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
SP_API_AWS_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
